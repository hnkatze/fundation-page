---
const valores = [
	{
		icon: '🎯',
		titulo: 'Misión',
		texto: 'Brindar e implementar nuevas estrategias para incluir socialmente y empoderar económicamente a nuestras poblaciones beneficiadas en Honduras; por medio de diferentes programas, actividades y alianzas estratégicas nacionales e internacionales.'
	},
	{
		icon: '🔭',
		titulo: 'Visión',
		texto: 'Ser la fundación líder en Honduras que brinde nuevas oportunidades socioeconómicas a través de las conexiones y las alianzas internacionales, implementando alternativas creativas, de impacto social y ambiental para fortalecer y replicar más programas inclusivos e innovadores que potencien la educación, el voluntariado y el emprendimiento.'
	},
	{
		icon: '💛',
		titulo: 'Público Meta',
		texto: 'Jóvenes, mujeres y personas con discapacidad. También familias de escasos recursos a través de proyectos de desarrollo social.'
	}
];

const actividades = [
	'Entrenamientos',
	'Talleres',
	'Conferencias',
	'Capacitaciones',
	'Eventos nacionales e internacionales',
	'Programas de mentoría e incubación para emprendedores',
	'Actividades de Voluntariado',
	'Actividades de Desarrollo Social'
];
---

<section id="quienes-somos" class="py-20 lg:py-28 bg-warm">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="section-header text-center mb-16">
			<span class="text-secondary font-semibold text-sm uppercase tracking-wider">Quiénes Somos</span>
			<h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 mt-3">
				Una fundación <span class="text-primary">comprometida con Honduras</span>
			</h2>
			<p class="mt-6 text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
				Somos un puente estratégico que impulsa el impacto social, el voluntariado y el empoderamiento económico en Honduras. Facilitamos el crecimiento de emprendedores sociales y ambientales, mujeres, jóvenes y personas con discapacidad, conectando su talento con oportunidades educativas, de emprendimiento y una sólida vinculación internacional que permite que sus soluciones lleguen a nuestras comunidades.
			</p>
			<p class="mt-4 text-base text-gray-500 max-w-3xl mx-auto leading-relaxed">
				Fuimos constituidos el 23 de marzo de 2018 en San Pedro Sula. Nuestro trabajo inició como un emprendimiento social desde 2011. Fundada por Karen Yesenia Madrid Morales, contamos con cobertura a nivel nacional.
			</p>
		</div>

		<div class="valores-grid grid md:grid-cols-3 gap-8">
			{valores.map((item, i) => (
				<div class="valor-card gsap-hidden bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
					<span class="text-4xl">{item.icon}</span>
					<h3 class="text-xl font-bold text-gray-900 mt-4 mb-3">{item.titulo}</h3>
					<p class="text-gray-600 leading-relaxed">{item.texto}</p>
				</div>
			))}
		</div>

		<div class="gsap-hidden mt-16">
			<h3 class="text-xl font-bold text-gray-900 text-center mb-8">¿Qué hacemos?</h3>
			<div class="flex flex-wrap justify-center gap-3">
				{actividades.map(a => (
					<span class="bg-white px-4 py-2 rounded-full text-sm font-medium text-primary shadow-sm border border-gray-100">
						{a}
					</span>
				))}
			</div>
		</div>
	</div>
</section>
