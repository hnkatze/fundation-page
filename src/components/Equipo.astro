---
const fundadora = {
	nombre: 'Karen Madrid',
	nombreCompleto: 'Karen Yesenia Madrid Morales',
	cargo: 'Fundadora & Directora Ejecutiva',
	descripcion: 'Emprendedora social hondureña con más de 10 años de experiencia en la gestión de proyectos sociales, desarrollo de alianzas estratégicas, relaciones internacionales y dirección de programas de impacto social.',
};
---

<section id="equipo" class="py-20 lg:py-28 bg-warm">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div data-animate class="text-center mb-16">
			<span class="text-secondary font-semibold text-sm uppercase tracking-wider">Liderazgo</span>
			<h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 mt-3">
				Nuestra <span class="text-primary">fundadora</span>
			</h2>
		</div>

		<div data-animate class="max-w-2xl mx-auto text-center">
			<div class="bg-primary w-24 h-24 rounded-full flex items-center justify-center text-white text-3xl font-bold mx-auto mb-6">
				KM
			</div>
			<h3 class="text-2xl font-bold text-gray-900">{fundadora.nombre}</h3>
			<p class="text-primary font-medium mt-1">{fundadora.cargo}</p>
			<p class="text-sm text-gray-500 mt-1">{fundadora.nombreCompleto}</p>
			<p class="text-gray-600 mt-6 leading-relaxed max-w-xl mx-auto">{fundadora.descripcion}</p>

			<div class="mt-10 pt-8 border-t border-gray-200">
				<p class="text-gray-500 mb-4">¿Te gustaría ser parte del cambio?</p>
				<a href="#contacto" class="inline-block bg-primary hover:bg-primary-light text-white font-semibold px-8 py-3 rounded-full transition-colors">
					Únete a nuestro equipo
				</a>
			</div>
		</div>
	</div>
</section>
