---
/* DATA — reemplazar con el JSON del cliente cuando llegue.
   Estructura: /NUEVOS_PROYECTOS_GUIA.md
   Cuando el array tenga elementos, el render cambia automáticamente de "Próximamente" a las cards.
   Campos: titulo, categoria, descripcion, fechaInicio, duracion, aliados, meta, estado, imagen */

interface NuevoProyecto {
	titulo: string;
	categoria: string;
	descripcion: string;
	fechaInicio: string;
	duracion: string;
	aliados: string;
	meta: string;
	estado: string;
	imagen: string;
}

const nuevosProyectos: NuevoProyecto[] = [];

const estadoStyles: Record<string, string> = {
	'En planificación': 'bg-blue-100 text-blue-700',
	'Próximamente': 'bg-secondary/10 text-secondary',
	'Buscando aliados': 'bg-highlight/20 text-orange-700',
};

const categoriaColors: Record<string, string> = {
	'Emprendimiento': 'bg-primary',
	'Educación': 'bg-secondary',
	'Vinculación Internacional': 'bg-accent',
	'Democracia': 'bg-peach',
	'Desarrollo Social': 'bg-mint',
};
---

<section id="nuevos-proyectos" class="py-20 lg:py-28 bg-white">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="section-header text-center mb-16">
			<span class="text-secondary font-semibold text-sm uppercase tracking-wider">Próximamente</span>
			<h2 class="text-3xl sm:text-4xl lg:text-6xl font-extrabold text-gray-900 mt-3 tracking-tight">
				Nuevos <span class="text-primary">Proyectos</span>
			</h2>
			<p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
				Iniciativas que pondremos en marcha próximamente y que marcarán la nueva etapa de la fundación.
			</p>
		</div>

		{nuevosProyectos.length === 0 ? (
			<div class="gsap-hidden max-w-3xl mx-auto">
				<div class="relative bg-gradient-to-br from-primary/5 via-white to-secondary/5 border border-primary/10 rounded-3xl p-12 lg:p-16 text-center overflow-hidden">
					<div class="absolute top-0 left-0 w-40 h-40 bg-primary/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
					<div class="absolute bottom-0 right-0 w-40 h-40 bg-secondary/10 rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>

					<div class="relative z-10">
						<div class="inline-flex w-20 h-20 rounded-2xl bg-primary/10 items-center justify-center mb-6">
							<svg class="w-10 h-10 text-primary animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
							</svg>
						</div>

						<h3 class="text-2xl lg:text-3xl font-extrabold text-gray-900 mb-3 tracking-tight">
							Estamos preparando algo grande
						</h3>
						<p class="text-gray-600 max-w-xl mx-auto leading-relaxed mb-8">
							Muy pronto vamos a compartir los nuevos proyectos que estamos diseñando para seguir transformando comunidades en Honduras.
						</p>

						<div class="inline-flex items-center gap-3 bg-white rounded-full px-5 py-2.5 shadow-sm border border-gray-100">
							<span class="relative flex h-2.5 w-2.5">
								<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
								<span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary"></span>
							</span>
							<span class="text-sm font-semibold text-primary uppercase tracking-wider">Próximamente</span>
						</div>

						<div class="mt-10 pt-8 border-t border-gray-200/60">
							<p class="text-sm text-gray-500 mb-4">¿Querés ser parte de estos nuevos proyectos?</p>
							<a href="#contacto" class="inline-flex items-center gap-2 text-primary font-semibold hover:gap-3 transition-all">
								Contactanos
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</a>
						</div>
					</div>
				</div>
			</div>
		) : (
			<div class="nuevos-proyectos-grid grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{nuevosProyectos.map(proyecto => (
					<article class="nuevo-proyecto-card gsap-hidden relative bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 group hover:-translate-y-1 border border-gray-100 flex flex-col">
						<div class="relative h-44 overflow-hidden">
							{proyecto.imagen ? (
								<img
									src={proyecto.imagen}
									alt={proyecto.titulo}
									class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
									loading="lazy"
								/>
							) : (
								<div class:list={[
									'w-full h-full flex items-center justify-center relative overflow-hidden',
									categoriaColors[proyecto.categoria] || 'bg-primary',
								]}>
									<div class="absolute inset-0 bg-gradient-to-br from-white/10 to-transparent"></div>
									<svg class="w-20 h-20 text-white/40 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
									</svg>
								</div>
							)}

							<span class:list={[
								'absolute top-3 right-3 text-xs font-semibold px-2.5 py-1 rounded-full backdrop-blur-md',
								estadoStyles[proyecto.estado] || 'bg-white/90 text-gray-700',
							]}>
								{proyecto.estado}
							</span>
						</div>

						<div class="p-6 flex-1 flex flex-col">
							<span class="text-xs font-semibold text-primary uppercase tracking-wider">{proyecto.categoria}</span>
							<h3 class="text-lg font-bold text-gray-900 mt-2 mb-2 group-hover:text-primary transition-colors leading-tight">
								{proyecto.titulo}
							</h3>
							<p class="text-gray-600 text-sm leading-relaxed mb-4">{proyecto.descripcion}</p>

							<div class="mt-auto space-y-2 pt-4 border-t border-gray-100">
								{proyecto.meta && (
									<div class="flex items-start gap-2">
										<svg class="w-4 h-4 text-primary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
										</svg>
										<p class="text-xs text-gray-600"><span class="font-semibold text-gray-800">Meta:</span> {proyecto.meta}</p>
									</div>
								)}

								<div class="flex flex-wrap gap-2">
									{proyecto.fechaInicio && (
										<span class="text-xs text-gray-500 bg-gray-50 px-2 py-1 rounded inline-flex items-center gap-1">
											<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
											</svg>
											{proyecto.fechaInicio}
										</span>
									)}
									{proyecto.duracion && (
										<span class="text-xs text-gray-500 bg-gray-50 px-2 py-1 rounded">{proyecto.duracion}</span>
									)}
								</div>

								{proyecto.aliados && (
									<p class="text-xs text-gray-400 pt-1">
										<span class="font-semibold">Aliados:</span> {proyecto.aliados}
									</p>
								)}
							</div>
						</div>
					</article>
				))}
			</div>
		)}
	</div>
</section>
