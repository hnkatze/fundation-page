---
const year = new Date().getFullYear();

const links = {
	fundacion: [
		{ label: 'Quiénes Somos', href: '#quienes-somos' },
		{ label: 'Nuestros Pilares', href: '#pilares' },
		{ label: 'Equipo', href: '#equipo' },
		{ label: 'Transparencia', href: '#transparencia' },
	],
	programas: [
		{ label: 'Emprendimiento', href: '#pilares' },
		{ label: 'Educación y Discapacidad', href: '#pilares' },
		{ label: 'Vinculación Internacional', href: '#pilares' },
		{ label: 'Democracia', href: '#pilares' },
		{ label: 'Desarrollo Social', href: '#pilares' },
	],
	involucrate: [
		{ label: 'Dona Ahora', href: '#como-ayudar' },
		{ label: 'Voluntariado', href: '#como-ayudar' },
		{ label: 'Alianzas', href: '#como-ayudar' },
		{ label: 'Contacto', href: '#contacto' },
	],
};
---

<footer class="bg-gray-900 text-white">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
		<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10">
			<div>
				<div class="mb-4">
					<img src="https://res.cloudinary.com/dfnsygose/image/upload/v1773695720/Logo_Blanco_HS_1_2_mdjntk.png" alt="Honduras Social" class="h-12 w-auto" />
				</div>
				<p class="text-gray-400 text-sm leading-relaxed mb-6">
					Transformando comunidades a través de la educación, el emprendimiento y la inclusión social en Honduras.
				</p>
				<p class="text-gray-500 text-xs">
					Fundación No Gubernamental de Desarrollo Honduras Social<br />
					Personería Jurídica: PJ-09022018-87<br />
					RTN: 05019019089184<br />
					San Pedro Sula, Honduras
				</p>
			</div>

			<div>
				<h4 class="font-bold text-sm uppercase tracking-wider mb-4 text-gray-300">Fundación</h4>
				<ul class="space-y-2">
					{links.fundacion.map(link => (
						<li>
							<a href={link.href} class="text-gray-400 hover:text-white text-sm transition-colors">{link.label}</a>
						</li>
					))}
				</ul>
			</div>

			<div>
				<h4 class="font-bold text-sm uppercase tracking-wider mb-4 text-gray-300">Programas</h4>
				<ul class="space-y-2">
					{links.programas.map(link => (
						<li>
							<a href={link.href} class="text-gray-400 hover:text-white text-sm transition-colors">{link.label}</a>
						</li>
					))}
				</ul>
			</div>

			<div>
				<h4 class="font-bold text-sm uppercase tracking-wider mb-4 text-gray-300">Involúcrate</h4>
				<ul class="space-y-2">
					{links.involucrate.map(link => (
						<li>
							<a href={link.href} class="text-gray-400 hover:text-white text-sm transition-colors">{link.label}</a>
						</li>
					))}
				</ul>
			</div>
		</div>
	</div>

	<div class="border-t border-gray-800">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
			<p class="text-gray-500 text-sm">
				&copy; {year} Honduras Social. Todos los derechos reservados.
			</p>
			<div class="flex gap-6 text-sm">
				<a href="#" class="text-gray-500 hover:text-gray-300 transition-colors">Política de Privacidad</a>
				<a href="#" class="text-gray-500 hover:text-gray-300 transition-colors">Términos de Uso</a>
			</div>
		</div>
	</div>

	<div class="border-t border-gray-800/50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4 text-xs text-gray-600">
			<span>Sitio desarrollado por</span>
			<a href="https://camilohenriquez.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white font-medium transition-colors">
				camilohenriquez.com
			</a>
			<span class="hidden sm:inline text-gray-700">|</span>
			<div class="flex items-center gap-3">
				<a href="mailto:contact@camilohenriquez.com" class="text-gray-500 hover:text-white transition-colors" aria-label="Email">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
				</a>
				<a href="https://github.com/hnkatze" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white transition-colors" aria-label="GitHub">
					<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
				</a>
				<a href="https://linkedin.com/in/hnkatze" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white transition-colors" aria-label="LinkedIn">
					<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
				</a>
			</div>
		</div>
	</div>
</footer>
