---

---

<section class="relative min-h-screen flex items-center justify-center bg-gradient-to-br from-primary-dark via-primary to-primary-light overflow-hidden">
	<!-- TODO [IMAGEN]: Reemplazar placeholder por foto real de la fundacion
	     Archivo: /images/hero-bg.webp (1920x1080 min, oscura o con overlay) -->
	<div class="absolute inset-0">
		<img src="https://res.cloudinary.com/dfnsygose/image/upload/v1773691861/hero-bg-overlay-preview_i4dazn.webp" alt="" class="w-full h-full object-cover opacity-20" />
	</div>

	<div class="absolute inset-0 opacity-10">
		<div class="parallax-blob absolute top-20 left-10 w-72 h-72 bg-secondary rounded-full blur-3xl animate-float-slow will-change-transform"></div>
		<div class="parallax-blob absolute bottom-20 right-10 w-96 h-96 bg-accent rounded-full blur-3xl animate-float-slower will-change-transform"></div>
	</div>

	<div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center pt-20">
		<span class="hero-badge gsap-hidden inline-block bg-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full mb-6 backdrop-blur-sm">
			Fortaleciendo comunidades desde 2011
		</span>

		<h1 class="hero-title gsap-hidden text-4xl sm:text-5xl lg:text-7xl font-extrabold text-white leading-tight mb-6">
			Empoderando <span class="text-highlight">mujeres</span>, jóvenes y personas con discapacidad en Honduras
		</h1>

		<p class="hero-subtitle gsap-hidden text-lg sm:text-xl text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed">
			Fortalecemos comunidades a través del emprendimiento, la educación, el voluntariado y la cooperación internacional, creando oportunidades reales para poblaciones vulnerables.
		</p>

		<div class="hero-cta flex flex-col sm:flex-row items-center justify-center gap-4">
			<a href="#como-ayudar" class="bg-secondary hover:bg-secondary-light text-white font-bold px-8 py-4 rounded-full text-lg transition-all hover:scale-105 shadow-lg">
				Dona Ahora
			</a>
			<a href="#quienes-somos" class="border-2 border-white/40 hover:border-white text-white font-semibold px-8 py-4 rounded-full text-lg transition-all hover:bg-white/10">
				Conócenos
			</a>
		</div>

		<div class="hero-stats mt-16 grid grid-cols-2 sm:grid-cols-4 gap-8 text-white/90">
			<div>
				<p class="text-3xl sm:text-4xl font-extrabold">10+</p>
				<p class="text-sm text-white/60 mt-1">Años de experiencia</p>
			</div>
			<div>
				<p class="text-3xl sm:text-4xl font-extrabold">12+</p>
				<p class="text-sm text-white/60 mt-1">Proyectos ejecutados</p>
			</div>
			<div>
				<p class="text-3xl sm:text-4xl font-extrabold">9</p>
				<p class="text-sm text-white/60 mt-1">Premios recibidos</p>
			</div>
			<div>
				<p class="text-3xl sm:text-4xl font-extrabold">14+</p>
				<p class="text-sm text-white/60 mt-1">Redes internacionales</p>
			</div>
		</div>
	</div>

	<div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
		<a href="#quienes-somos" class="text-white/50 hover:text-white transition-colors">
			<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
			</svg>
		</a>
	</div>
</section>
