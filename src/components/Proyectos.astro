---

<section id="proyectos" class="py-20 lg:py-28 bg-warm">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="section-header text-center mb-16">
			<span class="text-secondary font-semibold text-sm uppercase tracking-wider">Proyectos</span>
			<h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 mt-3">
				Iniciativas que <span class="text-primary">generan cambio</span>
			</h2>
			<p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
				Conoce los programas que están transformando la realidad de miles de hondureños.
			</p>
		</div>

		<div class="proyectos-grid grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
			{proyectos.map((proyecto, i) => (
				<div class="proyecto-card gsap-hidden bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow group">
					<div class:list={[proyecto.color, "h-2"]}></div>
					<div class="p-6">
						<div class="flex items-center justify-between mb-3">
							<span class="text-xs font-semibold text-primary uppercase tracking-wider">{proyecto.categoria}</span>
							<span class:list={[
								"text-xs font-medium px-2.5 py-0.5 rounded-full",
								proyecto.estado === 'En curso' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600'
							]}>
								{proyecto.estado}
							</span>
						</div>
						<h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-primary transition-colors">{proyecto.titulo}</h3>
						<p class="text-gray-600 text-sm leading-relaxed">{proyecto.descripcion}</p>
						<div class="mt-3 flex flex-wrap gap-2">
							{proyecto.anio && (
								<span class="text-xs text-gray-500 bg-gray-50 px-2 py-1 rounded">{proyecto.anio}</span>
							)}
							{proyecto.duracion && (
								<span class="text-xs text-gray-500 bg-gray-50 px-2 py-1 rounded">{proyecto.duracion}</span>
							)}
						</div>
						{proyecto.socios && (
							<p class="text-xs text-gray-400 mt-2">Aliados: {proyecto.socios}</p>
						)}
					</div>
				</div>
			))}
		</div>
	</div>
</section>
