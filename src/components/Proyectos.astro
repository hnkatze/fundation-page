---

<section id="proyectos" class="py-20 lg:py-28 bg-warm">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="section-header text-center mb-12">
			<span class="text-secondary font-semibold text-sm uppercase tracking-wider">Proyectos</span>
			<h2 class="text-3xl sm:text-4xl lg:text-6xl font-extrabold text-gray-900 mt-3 tracking-tight">
				Iniciativas que <span class="text-primary">generan cambio</span>
			</h2>
			<p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
				Conoce los programas que están transformando la realidad de miles de hondureños.
			</p>
		</div>

		<div class="gsap-hidden flex flex-wrap justify-center gap-2 sm:gap-3 mb-12" role="tablist" aria-label="Filtrar proyectos por categoría">
			{categorias.map((cat, i) => (
				<button
					type="button"
					class:list={[
						'proyecto-filter px-4 sm:px-5 py-2 rounded-full text-sm font-semibold transition-all border',
						i === 0
							? 'bg-primary text-white border-primary shadow-md'
							: 'bg-white text-gray-600 border-gray-200 hover:border-primary hover:text-primary',
					]}
					data-filter={cat}
					aria-pressed={i === 0 ? 'true' : 'false'}
				>
					{cat}
				</button>
			))}
		</div>

		<div class="proyectos-grid grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
			{proyectos.map(proyecto => (
				<article
					class="proyecto-card gsap-hidden bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 group hover:-translate-y-1"
					data-categoria={proyecto.categoria}
				>
					<div class="relative h-48 overflow-hidden">
						{proyecto.imagen ? (
							<img src={proyecto.imagen} alt={proyecto.titulo} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy" />
						) : (
							<div class:list={[proyecto.color, "w-full h-full"]}></div>
						)}

						<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

						<div class="absolute inset-x-0 bottom-0 p-5 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
							<span class="inline-flex items-center gap-2 text-white font-semibold text-sm">
								Ver proyecto
								<svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</span>
						</div>

						<span class:list={[
							"absolute top-3 right-3 text-xs font-semibold px-2.5 py-1 rounded-full backdrop-blur-md",
							proyecto.estado === 'En curso' ? 'bg-green-500/90 text-white' : 'bg-white/90 text-gray-700'
						]}>
							{proyecto.estado}
						</span>
					</div>

					<div class="p-6">
						<span class="text-xs font-semibold text-primary uppercase tracking-wider">{proyecto.categoria}</span>
						<h3 class="text-lg font-bold text-gray-900 mt-2 mb-2 group-hover:text-primary transition-colors leading-tight">{proyecto.titulo}</h3>
						<p class="text-gray-600 text-sm leading-relaxed">{proyecto.descripcion}</p>
						<div class="mt-4 flex flex-wrap gap-2">
							{proyecto.anio && (
								<span class="text-xs text-gray-500 bg-gray-50 px-2 py-1 rounded">{proyecto.anio}</span>
							)}
							{proyecto.duracion && (
								<span class="text-xs text-gray-500 bg-gray-50 px-2 py-1 rounded">{proyecto.duracion}</span>
							)}
						</div>
						{proyecto.socios && (
							<p class="text-xs text-gray-400 mt-3">Aliados: {proyecto.socios}</p>
						)}
					</div>
				</article>
			))}
		</div>

		<p class="proyectos-empty hidden text-center text-gray-500 mt-12">
			No hay proyectos en esta categoría.
		</p>
	</div>
</section>

<script>
	import { gsap } from 'gsap';

	const buttons = document.querySelectorAll<HTMLButtonElement>('.proyecto-filter');
	const cards = document.querySelectorAll<HTMLElement>('.proyecto-card');
	const emptyState = document.querySelector<HTMLElement>('.proyectos-empty');

	function filterProyectos(filter: string): void {
		let visibleCount = 0;

		cards.forEach(card => {
			const matches = filter === 'Todos' || card.dataset.categoria === filter;

			if (matches) {
				card.style.display = '';
				gsap.fromTo(card,
					{ opacity: 0, y: 20, scale: 0.95 },
					{ opacity: 1, y: 0, scale: 1, duration: 0.4, ease: 'power2.out' }
				);
				visibleCount++;
			} else {
				gsap.to(card, {
					opacity: 0, y: 20, scale: 0.95, duration: 0.25, ease: 'power2.in',
					onComplete: () => { card.style.display = 'none'; },
				});
			}
		});

		emptyState?.classList.toggle('hidden', visibleCount > 0);
	}

	buttons.forEach(btn => {
		btn.addEventListener('click', () => {
			const filter = btn.dataset.filter || 'Todos';

			buttons.forEach(b => {
				const active = b === btn;
				b.setAttribute('aria-pressed', active ? 'true' : 'false');
				b.classList.toggle('bg-primary', active);
				b.classList.toggle('text-white', active);
				b.classList.toggle('border-primary', active);
				b.classList.toggle('shadow-md', active);
				b.classList.toggle('bg-white', !active);
				b.classList.toggle('text-gray-600', !active);
				b.classList.toggle('border-gray-200', !active);
			});

			filterProyectos(filter);
		});
	});
</script>
