---
interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: string;
	canonical?: string;
}

const {
	title = 'Honduras Social — Fundación para el Desarrollo Comunitario',
	description = 'Fundación sin fines de lucro dedicada a fortalecer comunidades de mujeres, jóvenes y personas con discapacidad en Honduras a través del emprendimiento, la educación, el voluntariado y la cooperación internacional.',
	image = 'https://res.cloudinary.com/dfnsygose/image/upload/v1773693410/og-image-profesional_aag8q8.png',
	type = 'website',
	canonical,
} = Astro.props;

const siteUrl = 'https://www.hondurassocial.org';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(image, siteUrl).href;

import '../styles/global.css';
---
<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- Primary Meta -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="generator" content={Astro.generator} />

		<!-- Favicons -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="32x32" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="theme-color" content="#6B4A96" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:site_name" content="Fundación Honduras Social" />
		<meta property="og:locale" content="es_HN" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalUrl} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- SEO Extras -->
		<meta name="robots" content="index, follow" />
		<meta name="author" content="Fundación Honduras Social" />
		<meta name="keywords" content="fundación, Honduras, ONG, emprendimiento, educación, discapacidad, mujeres, jóvenes, voluntariado, cooperación internacional, San Pedro Sula, inclusión social, desarrollo comunitario" />

		<!-- Geo -->
		<meta name="geo.region" content="HN-CR" />
		<meta name="geo.placename" content="San Pedro Sula" />
		<meta name="geo.position" content="15.5;-88.03" />
		<meta name="ICBM" content="15.5, -88.03" />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

		<!-- Structured Data (JSON-LD) -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "NGO",
			"name": "Fundación No Gubernamental de Desarrollo Honduras Social",
			"alternateName": "Honduras Social",
			"url": siteUrl,
			"logo": `${siteUrl}/favicon.svg`,
			"description": description,
			"foundingDate": "2018-03-23",
			"founder": {
				"@type": "Person",
				"name": "Karen Madrid",
				"jobTitle": "Fundadora & Directora Ejecutiva"
			},
			"address": {
				"@type": "PostalAddress",
				"addressLocality": "San Pedro Sula",
				"addressCountry": "HN"
			},
			"telephone": "+504 8929-3414",
			"email": "karen.madrid@hondurassocial.org",
			"sameAs": [],
			"areaServed": {
				"@type": "Country",
				"name": "Honduras"
			},
			"nonprofitStatus": "Nonprofit501c3",
			"keywords": "emprendimiento, educación, discapacidad, voluntariado, cooperación internacional"
		})} />
	</head>
	<body class="m-0 w-full bg-white text-gray-800 font-body antialiased">
		<slot />

		<script>
			import '../scripts/animations.ts';
		</script>

		<noscript><style>.gsap-hidden { opacity: 1 !important; }</style></noscript>
	</body>
</html>
